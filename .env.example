# Feellog 환경변수 예시 — 이 파일을 .env 로 복사한 뒤 값을 채우세요.
# EXPO_PUBLIC_ 접두사가 붙은 변수만 클라이언트 번들에 주입됩니다(공개되어도 안전한 값만).
# ⚠️ 실제 값은 .env 에만 넣으세요. 이 파일(.env.example)은 빈 템플릿으로 유지합니다.

# Supabase: 대시보드 > Project Settings > API 에서 복사
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# (Phase 1에서 추가) 카카오 로그인 / 카카오맵
# EXPO_PUBLIC_KAKAO_JS_KEY=
# EXPO_PUBLIC_KAKAO_NATIVE_APP_KEY=
