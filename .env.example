# Feellog 환경변수 예시 — 이 파일을 .env 로 복사한 뒤 값을 채우세요.
# EXPO_PUBLIC_ 접두사가 붙은 변수만 클라이언트 번들에 주입됩니다(공개되어도 안전한 값만).
# ⚠️ 실제 값은 .env 에만 넣으세요. 이 파일(.env.example)은 빈 템플릿으로 유지합니다.

# Supabase: 대시보드 > Project Settings > API 에서 복사
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# 카카오 로그인(OIDC). 카카오 개발자 콘솔 > 앱 키 > REST API 키.
# (authorize URL의 client_id로 쓰이며 공개되어도 되는 값. 비어 있으면 카카오 로그인 동작 안 함)
EXPO_PUBLIC_KAKAO_REST_API_KEY=
# ⚠️ 카카오 Client Secret은 클라이언트에 두지 않는다. Edge Function 시크릿으로만 등록:
#   supabase secrets set KAKAO_REST_API_KEY=... KAKAO_CLIENT_SECRET=...
